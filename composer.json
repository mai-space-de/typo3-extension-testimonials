{
    "name": "maispace/mai-testimonials",
    "description": "Testimonials extension with slider, grid, and single-quote layouts. Records store quote text, author name, role, organisation, portrait image (FAL), and sys_category. Supports category filtering and a Story Wall for community testimonials.",
    "type": "typo3-cms-extension",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Maispace",
            "role": "Developer"
        }
    ],
    "require": {
        "maispace/mai-base": "@dev",
        "typo3/cms-core": "^14.1",
        "typo3/cms-extbase": "^14.1",
        "typo3/cms-fluid": "^14.1"
    },
    "autoload": {
        "psr-4": {
            "Maispace\\MaiTestimonials\\": "Classes"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Maispace\\MaiTestimonials\\Tests\\": "Tests"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "mai_testimonials"
        },
        "branch-alias": {
            "dev-main": "14.0.x-dev"
        }
    },
    "scripts": {
        "lint:check": [
            "@check:editorconfig",
            "@check:phpcs",
            "@check:phpstan",
            "@check:typoscript",
            "@composer validate --strict --no-check-version --no-check-all --no-check-publish"
        ],
        "lint:fix": [
            "@fix:editorconfig",
            "@fix:phpcs",
            "@check:phpstan",
            "@check:typoscript"
        ],
        "check:editorconfig": "ec -unv -e vendor/ -e public/",
        "fix:editorconfig": "ec -unvf -e vendor/ -e public/",
        "check:phpcs": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer check --config .php-cs-fixer.php --ansi --verbose --diff",
        "fix:phpcs": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix --config .php-cs-fixer.php --ansi",
        "check:phpstan": "phpstan analyse --no-progress",
        "check:phpstan:baseline": "phpstan analyse --no-progress --generate-baseline=phpstan-baseline.neon",
        "check:typoscript": "typoscript-lint --fail-on-warnings -c typoscript-lint.yml Configuration/",
        "test": "phpunit --configuration phpunit.xml.dist",
        "test:unit": "phpunit --configuration phpunit.xml.dist --testsuite Unit"
    },
    "config": {
        "allow-plugins": {
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true
        },
        "sort-packages": true
    }
}
